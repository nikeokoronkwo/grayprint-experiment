# ─────────────────────────────────────────────────────────────
# Grayprint — environment template
# Copy to .env (or apps/web/.env) for local dev.
# ─────────────────────────────────────────────────────────────

# Public
PUBLIC_SITE_URL=http://localhost:3000

# Database (Postgres). Locally NuxtHub falls back to PGLite if unset.
DATABASE_URL=postgresql://grayprint:grayprint@localhost:5432/grayprint

# better-auth
BETTER_AUTH_SECRET=replace-with-a-32+char-random-string
BETTER_AUTH_URL=http://localhost:3000

# Email (SMTP — swap to any provider; Resend SMTP is a good free starter)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_api_key
SMTP_FROM="Grayprint <hello@grayprint.dev>"

# Polar (sandbox while testing; switch to production later)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_ENVIRONMENT=sandbox
POLAR_PRODUCT_PRO_ID=
POLAR_SUCCESS_URL=http://localhost:3000/dashboard/billing?checkout_id={CHECKOUT_ID}

# Blob storage (Vercel Blob in prod; left empty falls back to local fs in dev)
BLOB_READ_WRITE_TOKEN=

# Dub (Level 1 — leave empty for Level 0)
DUB_API_KEY=
