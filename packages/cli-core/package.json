{
  "name": "@grayprint/cli-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared CLI logic for grayprint and create-grayprint — auth, config, registry awareness.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "@grayprint/schemas": "workspace:*",
    "@grayprint/sdk": "workspace:*",
    "ofetch": "^1.4.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2"
  }
}
