{
  "name": "@grayprint/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Authenticated Model Context Protocol server for Grayprint — stdio and HTTP transports.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "import": "./src/http.ts"
    },
    "./stdio": {
      "types": "./src/stdio.ts",
      "import": "./src/stdio.ts"
    }
  },
  "bin": {
    "grayprint-mcp": "./bin/mcp.mjs"
  },
  "scripts": {
    "dev": "tsx src/stdio.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@grayprint/cli-core": "workspace:*",
    "@grayprint/schemas": "workspace:*",
    "@grayprint/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
