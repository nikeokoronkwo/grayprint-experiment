{
  "name": "@grayprint/sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Typed registry client for Grayprint — used by the CLIs and the MCP server.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@grayprint/schemas": "workspace:*",
    "ofetch": "^1.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2"
  }
}
