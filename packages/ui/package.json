{
  "name": "@grayprint/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Grayprint design system — design tokens, GSAP utilities, Tailwind 4 @theme.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens.ts",
      "import": "./src/tokens.ts",
      "default": "./src/tokens.ts"
    },
    "./gsap": {
      "types": "./src/gsap.ts",
      "import": "./src/gsap.ts",
      "default": "./src/gsap.ts"
    },
    "./theme.css": "./src/theme.css",
    "./assets/logo.svg": "./assets/logo.svg",
    "./assets/logomark.svg": "./assets/logomark.svg"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "gsap": "^3.12.5",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
